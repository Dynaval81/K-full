generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String    @id @default(uuid())
  email                 String    @unique
  password              String

  // Knoty fields
  firstName             String?
  lastName              String?
  knNumber              String?   @unique
  role                  String?   @default("student")       // student|parent|teacher|schoolAdmin|appAdmin
  verificationLevel     String?   @default("sandbox")       // sandbox|schoolVerified|fullyVerified
  isApproved            Boolean   @default(false)
  status                String    @default("active")        // active|banned|deleted
  schoolId              String?
  classId               String?
  banReason             String?
  bannedAt              DateTime?
  bannedBy              String?

  // Legacy vtalk fields (kept for migration safety)
  username              String?   @unique
  vtNumber              String?   @unique
  emailVerified         Boolean   @default(false)
  emailVerificationToken String?
  isBanned              Boolean   @default(false)
  isPremium             Boolean   @default(false)
  premiumPlan           String?
  premiumExpiresAt      DateTime?
  premiumActivatedWith  String?
  hasVpnAccess          Boolean   @default(false)
  vpnExpiresAt          DateTime?
  hasAiAccess           Boolean   @default(false)
  aiExpiresAt           DateTime?
  lastUsernameChangeAt  DateTime?
  lastLoginAt           DateTime?
  lastLoginIp           String?
  registrationIp        String?
  lastDevice            String?
  lastPlatform          String?
  appVersion            String?
  country               String?
  city                  String?
  matrixUserId          String?   @unique
  matrixAccessToken     String?
  region                String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  school                School?   @relation(fields: [schoolId], references: [id])
  loginHistory          LoginHistory[]
  sessions              Session[]

  @@index([email])
  @@index([knNumber])
}

model School {
  id          String    @id @default(uuid())
  name        String
  city        String
  address     String?
  adminId     String?
  createdAt   DateTime  @default(now())

  users            User[]
  activationCodes  ActivationCode[]

  @@index([name])
}

model ActivationCode {
  code        String    @id
  schoolId    String
  school      School    @relation(fields: [schoolId], references: [id])
  classId     String
  role        String    @default("student")  // student|teacher
  firstName   String
  lastName    String
  status      String    @default("unused")   // unused|used|expired
  usedBy      String?
  expiresAt   DateTime
  createdBy   String
  createdAt   DateTime  @default(now())

  @@index([schoolId])
  @@index([status])
}

model ActivationPassword {
  id            String    @id @default(uuid())
  password      String    @unique
  plan          String
  duration      Int
  maxUses       Int       @default(1)
  currentUses   Int       @default(0)
  isActive      Boolean   @default(true)
  createdBy     String    @default("admin")
  createdAt     DateTime  @default(now())

  @@index([password])
}

model LoginHistory {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ip          String
  userAgent   String?
  platform    String?
  country     String?
  city        String?
  success     Boolean  @default(true)
  timestamp   DateTime @default(now())

  @@index([userId])
  @@index([timestamp])
}

model Session {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token       String   @unique
  ip          String
  device      String?
  platform    String?
  createdAt   DateTime @default(now())
  expiresAt   DateTime
  lastActive  DateTime @default(now())
  isActive    Boolean  @default(true)

  @@index([userId])
  @@index([token])
}

model BannedEmail {
  id               String   @id @default(uuid())
  email            String   @unique
  previousUsername String?
  previousVtNumber String?
  reason           String?
  bannedBy         String   @default("admin")
  bannedAt         DateTime @default(now())

  @@index([email])
}
