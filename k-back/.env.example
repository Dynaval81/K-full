# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development          # development | production

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/knoty?schema=public"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_secret

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (REQUIRED in production).
# In development, if unset, all origins are allowed.
# Example: https://app.knoty.de,https://admin.knoty.de
ALLOWED_ORIGINS=

# ─── Email (optional — email features disabled if unset) ──────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=smtp_password_here
EMAIL_FROM=Knoty <noreply@example.com>

# URL used to build email verification links
API_BASE_URL=https://your-domain.com

# ─── Logging ──────────────────────────────────────────────────────────────────
# trace | debug | info | warn | error | fatal  (default: info)
LOG_LEVEL=info
