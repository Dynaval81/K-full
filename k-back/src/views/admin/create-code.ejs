<h2 class="mb-4">Create Activation Code</h2>

<div class="row">
  <div class="col-md-6">
    <div class="card p-4">
      <form id="createCodeForm">
        <div class="mb-3">
          <label class="form-label">Password / Code</label>
          <div class="input-group">
            <input type="text" class="form-control" id="password" name="password" required>
            <button type="button" class="btn btn-secondary" onclick="generateCode()">
              <i class="bi bi-arrow-clockwise"></i> Generate
            </button>
          </div>
          <small class="text-muted">Leave empty to auto-generate</small>
        </div>

        <div class="mb-3">
          <label class="form-label">Plan</label>
          <select class="form-select" name="plan" required>
            <option value="premium">Premium (Full Access)</option>
            <option value="vpn_only">VPN Only</option>
            <option value="ai_only">AI Only</option>
          </select>
        </div>

        <div class="mb-3">
          <label class="form-label">Duration Type</label>
          <select class="form-select" id="durationType" onchange="toggleDuration()">
            <option value="days">Limited (Days)</option>
            <option value="lifetime">Lifetime (Permanent)</option>
          </select>
        </div>

        <div class="mb-3" id="durationDays">
          <label class="form-label">Number of Days</label>
          <input type="number" class="form-control" name="duration" id="durationInput" value="30" min="1">
        </div>

        <div class="mb-3">
          <label class="form-label">Max Uses</label>
          <input type="number" class="form-control" name="maxUses" value="1" required min="1">
        </div>

        <button type="submit" class="btn btn-primary w-100">
          <i class="bi bi-plus-circle"></i> Create Code
        </button>
      </form>

      <div id="result" class="mt-3"></div>
    </div>
  </div>
</div>

<script>
function generateCode() {
  const code = Math.random().toString(36).substring(2, 12).toUpperCase();
  document.getElementById('password').value = code;
}

function toggleDuration() {
  const type = document.getElementById('durationType').value;
  const daysDiv = document.getElementById('durationDays');
  const daysInput = document.getElementById('durationInput');
  
  if (type === 'lifetime') {
    daysDiv.style.display = 'none';
    daysInput.value = '0';
  } else {
    daysDiv.style.display = 'block';
    if (daysInput.value === '0') {
      daysInput.value = '30';
    }
  }
}

document.getElementById('createCodeForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const formData = new FormData(e.target);
  const data = Object.fromEntries(formData);
  
  const response = await fetch('/admin/codes/create', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(data)
  });
  
  const result = await response.json();
  
  if (result.success) {
    const durationText = result.data.duration === 0 ? 'Lifetime' : `${result.data.duration} days`;
    document.getElementById('result').innerHTML = `
      <div class="alert alert-success">
        <strong>✅ Code Created!</strong><br>
        Password: <code class="fs-5">${result.data.password}</code><br>
        Plan: ${result.data.plan}<br>
        Duration: ${durationText}<br>
        Max Uses: ${result.data.maxUses}<br>
        <a href="/admin/codes" class="btn btn-sm btn-primary mt-2">View All Codes</a>
      </div>
    `;
    e.target.reset();
  } else {
    document.getElementById('result').innerHTML = `
      <div class="alert alert-danger">❌ ${result.error}</div>
    `;
  }
});
</script>
