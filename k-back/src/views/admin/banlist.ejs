<div class="d-flex justify-content-between align-items-center mb-4">
  <h2>Banned Emails</h2>
</div>

<div class="card">
  <table class="table table-hover mb-0">
    <thead>
      <tr>
        <th>Email</th>
        <th>Previous Username</th>
        <th>Previous VT-Number</th>
        <th>Reason</th>
        <th>Banned At</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (bannedEmails.length === 0) { %>
        <tr><td colspan="6" class="text-center text-muted">No banned emails</td></tr>
      <% } else { %>
        <% bannedEmails.forEach(banned => { %>
        <tr>
          <td><strong><%= banned.email %></strong></td>
          <td><%= banned.previousUsername || 'N/A' %></td>
          <td><code><%= banned.previousVtNumber || 'N/A' %></code></td>
          <td><%= banned.reason || '-' %></td>
          <td><%= new Date(banned.bannedAt).toLocaleDateString() %></td>
          <td>
            <button class="btn btn-sm btn-success" onclick="unbanEmail('<%= banned.id %>', '<%= banned.email %>')">
              <i class="bi bi-unlock"></i> Unban
            </button>
          </td>
        </tr>
        <% }); %>
      <% } %>
    </tbody>
  </table>
</div>

<script>
function unbanEmail(id, email) {
  if (!confirm(`Unban ${email}?`)) return;
  
  fetch(`/admin/banlist/${id}/unban`, { method: 'POST' })
    .then(r => r.json())
    .then(() => location.reload());
}
</script>
