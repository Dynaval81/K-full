<h2 class="mb-4">Activation Codes</h2>

<div class="card">
  <table class="table table-hover mb-0">
    <thead>
      <tr>
        <th>Password</th>
        <th>Plan</th>
        <th>Duration</th>
        <th>Uses</th>
        <th>Status</th>
        <th>Created</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% codes.forEach(code => { %>
      <tr class="<%= code.currentUses >= code.maxUses ? 'table-secondary' : '' %>">
        <td><code><%= code.password %></code></td>
        <td><span class="badge bg-primary"><%= code.plan %></span></td>
        <td>
          <% if (code.duration === 0) { %>
            <span class="badge bg-success">Lifetime</span>
          <% } else { %>
            <%= code.duration %> days
          <% } %>
        </td>
        <td>
          <%= code.currentUses %> / <%= code.maxUses %>
          <% if (code.currentUses >= code.maxUses) { %>
            <span class="badge bg-danger">Exhausted</span>
          <% } %>
        </td>
        <td>
          <span class="badge bg-<%= code.isActive ? 'success' : 'secondary' %>">
            <%= code.isActive ? 'Active' : 'Inactive' %>
          </span>
        </td>
        <td><%= new Date(code.createdAt).toLocaleDateString() %></td>
        <td>
          <button class="btn btn-sm btn-danger" onclick="deleteCode('<%= code.id %>', '<%= code.password %>')">
            <i class="bi bi-trash"></i>
          </button>
        </td>
      </tr>
      <% }); %>
    </tbody>
  </table>
</div>

<script>
function deleteCode(id, password) {
  if (!confirm(`Delete code ${password}?\n\nThis action cannot be undone!`)) return;
  
  fetch(`/admin/codes/${id}/delete`, { method: 'POST' })
    .then(r => r.json())
    .then(data => {
      if (data.success) {
        location.reload();
      } else {
        alert('Error: ' + data.error);
      }
    });
}
</script>
