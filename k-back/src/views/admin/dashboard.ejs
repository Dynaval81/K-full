<h2 class="mb-4">Dashboard</h2>

<div class="row g-4 mb-4">
  <div class="col-md-3">
    <div class="card stat-card p-4">
      <h6>Total Users</h6>
      <h2><%= stats.totalUsers %></h2>
      <small><i class="bi bi-people"></i> Registered</small>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card stat-card p-4">
      <h6>Premium Users</h6>
      <h2><%= stats.premiumUsers %></h2>
      <small><i class="bi bi-star"></i> Active</small>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card stat-card p-4">
      <h6>VPN Nodes</h6>
      <h2><%= stats.vpnNodes %></h2>
      <small><i class="bi bi-server"></i> Active</small>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card stat-card p-4">
      <h6>Total Logins</h6>
      <h2><%= stats.totalLogins %></h2>
      <small><i class="bi bi-box-arrow-in-right"></i> All time</small>
    </div>
  </div>
</div>

<div class="card p-4">
  <h5>Recent Activity</h5>
  <p class="text-muted">VPN Connections: <%= stats.totalVpnConnections %></p>
  <p class="text-muted">Verified Users: <%= stats.verifiedUsers %></p>
</div>
